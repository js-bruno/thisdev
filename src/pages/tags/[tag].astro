---
import BlogLayout from "../../layouts/BlogLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  const tagMap = new Map<string, typeof posts>();

  posts.forEach((post) => {
    const tags = post.data.tags;
    if (!tags) return;
    const arr = Array.isArray(tags) ? tags : [tags];
    arr.forEach((tag) => {
      const slug = tag.toLowerCase().replace(/\s+/g, "-");
      if (!tagMap.has(slug)) tagMap.set(slug, []);
      tagMap.get(slug)!.push(post);
    });
  });

  return [...tagMap.entries()].map(([slug, tagPosts]) => ({
    params: { tag: slug },
    props: { tag: slug, tagPosts },
  }));
}

const { tag, tagPosts } = Astro.props;

const sorted = tagPosts.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
  const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
  return dateB - dateA;
});
---

<BlogLayout title={`Tagged '${tag}'`}>
  <h1>Tagged "{tag}"</h1>

  <ol
    reversed
    class="postlist"
    style={`--postlist-index: ${sorted.length + 1}`}
  >
    {
      sorted.map((post) => {
        const date = post.data.date ? new Date(post.data.date) : null;
        const htmlDate = date ? date.toISOString().split("T")[0] : null;
        const readableDate = date
          ? date.toLocaleDateString("en-US", { month: "long", year: "numeric", timeZone: "UTC" })
          : null;

        return (
          <li class="postlist-item">
            <a href={`/blog/${post.slug}/`} class="postlist-link">
              {post.data.title}
            </a>
            {htmlDate && (
              <time class="postlist-date" datetime={htmlDate}>
                {readableDate}
              </time>
            )}
          </li>
        );
      })
    }
  </ol>

  <p><span data-pt>Ver <a href="/tags/">todas as tags</a>.</span><span data-en>See <a href="/tags/">all tags</a>.</span></p>
</BlogLayout>
